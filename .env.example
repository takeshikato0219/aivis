# .env.example
# ============================================
# API CONFIGURATION
# ============================================
REACT_APP_API_URL=http://localhost:3000/api
REACT_APP_API_TIMEOUT=30000

# ============================================
# SONARQUBE (for local analysis)
# ============================================
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=your_sonar_token_here
SONAR_PROJECT_KEY=your_project_key

