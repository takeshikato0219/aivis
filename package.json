{
  "name": "Timima01App",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --ci --maxWorkers=2",
    "test:clear": "jest --clearCache",
    "test:update": "jest --updateSnapshot",
    "test:verbose": "jest --verbose",
    "test:components": "jest __tests__/components --coverage",
    "test:screens": "jest __tests__/screens --coverage",
    "test:redux": "jest __tests__/redux --coverage",
    "test:utils": "jest __tests__/utils --coverage",
    "test:integration": "jest __tests__/integration --coverage",
    "test:e2e": "jest __tests__/e2e --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2 --reporters=default --reporters=jest-junit",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json}\""
  },
