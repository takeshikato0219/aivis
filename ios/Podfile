# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '15.5'
prepare_react_native_project!

# Firebase iOS SDK v9+ requires use_frameworks (static linkage)
use_frameworks! :linkage => :static
$RNFirebaseAsStaticFramework = true

require_relative '../node_modules/react-native-permissions/scripts/setup'

setup_permissions([
  'Camera',
  'Microphone',
  'PhotoLibrary',
  'PhotoLibraryAddOnly',
  'Notifications'
])

target 'Timima01App' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |bc|
        bc.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.5'

        # Fix: fmt 11.x uses consteval (C++20) which causes build errors with newer Xcode/Clang
        flags = bc.build_settings['OTHER_CPLUSPLUSFLAGS'] || '$(inherited)'
        unless flags.include?('FMT_USE_CONSTEVAL')
          bc.build_settings['OTHER_CPLUSPLUSFLAGS'] = "#{flags} -DFMT_USE_CONSTEVAL=0"
        end
      end
    end

    # Fix: fmt 11.x consteval is broken in all Apple Clang (Xcode 26+)
    # Patch base.h to disable consteval for all Apple Clang builds
    fmt_base_h = File.join(installer.sandbox.root, 'fmt/include/fmt/base.h')
    if File.exist?(fmt_base_h)
      content = File.read(fmt_base_h)
      patched = content.gsub(
        '#elif defined(__apple_build_version__) && __apple_build_version__ < 14000029L',
        '#elif defined(__apple_build_version__)'
      )
      if patched != content
        FileUtils.chmod(0644, fmt_base_h)
        File.write(fmt_base_h, patched)
      end
    end

    # Fix: react-native-record-screen uses RPScreenRecorder (ReplayKit) but podspec doesn't declare it
    # Add ReplayKit to xcconfig so it persists across pod install
    ['Pods-Timima01App.debug.xcconfig', 'Pods-Timima01App.release.xcconfig'].each do |config_name|
      config_path = File.join(installer.sandbox.root, 'Target Support Files', 'Pods-Timima01App', config_name)
      if File.exist?(config_path)
        config_content = File.read(config_path)
        unless config_content.include?('ReplayKit')
          config_content = config_content.gsub(
            /(OTHER_LDFLAGS = .+)/,
            "\\1 -framework \"ReplayKit\""
          )
          File.write(config_path, config_content)
        end
      end
    end
  end
end
